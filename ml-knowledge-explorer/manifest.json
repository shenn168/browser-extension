{
  "manifest_version": 3,
  "name": "ML Knowledge Explorer",
  "version": "1.1.0",
  "description": "Explore, search, and refresh your knowledge on all types of Machine Learning.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://en.wikipedia.org/*",
    "https://export.arxiv.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_title": "Open ML Knowledge Explorer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}