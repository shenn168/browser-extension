{
  "manifest_version": 3,
  "name": "LinkedLens",
  "version": "1.0.1",
  "description": "Your intelligent LinkedIn companion — sentiment insights, smart bookmarks, time tracking, and keyboard productivity.",
  "permissions": [
    "storage",
    "alarms",
    "sidePanel",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": [
        "utils/storage.js",
        "utils/nlp-lite.js",
        "utils/dom-parser.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}